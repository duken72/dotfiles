## Create backup folder
if ! [ -d ~/config_backup ]; then
	mkdir -p ~/config_backup
fi

## autostart
if [ -d ~/.config/autostart ]; then
	mv -i ~/.config/autostart ~/config_backup/
fi
ln -s ~/dotfiles/.config/autostart ~/.config/autostart
## conky
if [ -d ~/.config/conky ]; then
	mv -i ~/.config/conky ~/config_backup/
fi
ln -s ~/dotfiles/.config/conky ~/.config/conky
## moc
if [ -d ~/.moc ]; then
	mkdir -p ~/config_backup/moc
	mv -i ~/.moc/* ~/config_backup/moc
fi
ln -s ~/dotfiles/.config/moc ~/.moc
